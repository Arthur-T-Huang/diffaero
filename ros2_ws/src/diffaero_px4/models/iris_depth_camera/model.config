<?xml version="1.0"?>
<model>
  <name>iris_depth_camera</name>
  <version>1.0</version>
  <sdf version="1.9">model.sdf</sdf>
  <description>
    Iris quadrotor with a forward-facing depth camera (16x9, 86° FOV, 5 m range).
    Matches the DiffAero SHA2C training sensor configuration (cfg/sensor/camera.yaml).
    Based on the standard PX4 iris model with a fixed depth sensor link added.
  </description>
</model>
